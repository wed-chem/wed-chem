rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Photographers — public read, owner write
    match /photographers/{photographerId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == photographerId;
      allow update: if request.auth != null && request.auth.uid == photographerId;
    }

    // Quiz sessions — anyone can create (anonymous), owner can read
    match /quizSessions/{sessionId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || resource.data.userId == null
      );
    }

    // Match results — created by system, readable by owner
    match /matchResults/{resultId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Inquiries — couples create, photographers read their own
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read: if request.auth != null && resource.data.photographerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.photographerId == request.auth.uid;
    }
  }
}
