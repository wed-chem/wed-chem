rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - owner can read/write own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Photographers - public read for approved, owner write, admin full access
    match /photographers/{photographerId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == photographerId;
      allow update: if request.auth != null && (
        request.auth.uid == photographerId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Quiz sessions - anyone can create, owner can read
    match /quizSessions/{sessionId} {
      allow create: if true;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Inquiries - anyone can create, photographer reads own
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.photographerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow update: if request.auth != null && resource.data.photographerId == request.auth.uid;
    }
  }
}
