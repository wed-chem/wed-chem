rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - owner can read/write own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Photographers - public read for approved, owner write, admin full access
    match /photographers/{photographerId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == photographerId;
      allow update: if request.auth != null && (
        request.auth.uid == photographerId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Allow anyone authed to increment profileViews only
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews']))
      );
    }

    // Quiz sessions - anyone can create, owner can read
    match /quizSessions/{sessionId} {
      allow create: if true;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Inquiries - anyone can create, photographer reads own, couple reads own
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.photographerId == request.auth.uid ||
        resource.data.coupleUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow update: if request.auth != null && resource.data.photographerId == request.auth.uid;
    }

    // Quiz results - owner can read/write
    match /quizResults/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Saved photographers - owner can read/write
    match /savedPhotographers/{docId} {
      allow read: if request.auth != null && resource.data.coupleUid == request.auth.uid;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.coupleUid == request.auth.uid;
    }

    // Photographer analytics - anyone authed can increment, owner can read
    match /photographerAnalytics/{photographerId} {
      allow read: if request.auth != null && request.auth.uid == photographerId;
      allow write: if request.auth != null;
    }
  }
}
