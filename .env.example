# Firebase Config — get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=wedchem-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=wedchem-app
VITE_FIREBASE_STORAGE_BUCKET=wedchem-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
